# ── Zoho Books ────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:8000/zoho/callback
ZOHO_ORGANIZATION_ID=
ZOHO_MOCK=true          # set to false only when hitting live Zoho

# ── Claude AI ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google Sheets ─────────────────────────────────────────────────
GOOGLE_SHEETS_CREDENTIALS_JSON=credentials.json   # path to service account JSON
GOOGLE_SHEET_ID=
SHEET_ENV=dev           # set to prod only for final demo

# ── Resend (email) ────────────────────────────────────────────────
RESEND_API_KEY=
FOUNDER_EMAIL=
ACCOUNTANT_EMAIL=

# ── Avalanche Fuji Testnet ────────────────────────────────────────
AVAX_PRIVATE_KEY=       # testnet wallet only — no real money
AVAX_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
